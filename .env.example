# Blog editor at /admin (the simple password-protected editor for Kristy)
# ADMIN_PASSWORD  - the password Kristy types to open the editor
# BLOG_GITHUB_TOKEN    - fine-grained GitHub personal access token with
#                   "Contents: Read and write" on pirut/kristyfitness;
#                   used server-side to save posts. Never exposed to browsers.
ADMIN_PASSWORD=
BLOG_GITHUB_TOKEN=

# Optional: Keystatic editor at /keystatic (GitHub sign-in; for developers)
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_GITHUB_APP_SLUG=
# KEYSTATIC_SECRET=
