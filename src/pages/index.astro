---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllPosts } from "../lib/blog";
import {
  DEFAULT_DESCRIPTION,
  EMAIL,
  MISSION,
  PHONE_DISPLAY,
  PHONE_TEL,
  SITE_NAME,
  SITE_URL,
} from "../lib/site";

export const prerender = true;

const latestPosts = (await getAllPosts()).slice(0, 3);

const jsonLd = [
  {
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    url: `${SITE_URL}/`,
    name: SITE_NAME,
    description: DEFAULT_DESCRIPTION,
    inLanguage: "en-US",
  },
  {
    "@type": "HealthAndBeautyBusiness",
    "@id": `${SITE_URL}/#business`,
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    slogan: "Join the Fit Life",
    description: DEFAULT_DESCRIPTION,
    telephone: PHONE_DISPLAY,
    email: EMAIL,
    founder: { "@id": `${SITE_URL}/#kristy` },
    makesOffer: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Water Training",
          description:
            "Low-impact, full-body water workouts that are gentle on joints — great for beginners, seniors, injury recovery, arthritis, and balance improvement.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Nutrition Coaching",
          description:
            "Practical nutrition guidance and personalized plans for weight management, energy, and long-term wellness.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "One-on-One Personal Training",
          description:
            "Individualized fitness programs for strength, flexibility, balance, and mobility, tailored to your fitness level and goals.",
        },
      },
    ],
  },
  {
    "@type": "Person",
    "@id": `${SITE_URL}/#kristy`,
    name: "Kristy Bussard",
    honorificSuffix: "FNLP",
    jobTitle: "Certified Health & Wellness Practitioner",
    telephone: PHONE_DISPLAY,
    email: EMAIL,
    url: `${SITE_URL}/`,
    hasCredential: [
      { "@type": "EducationalOccupationalCredential", name: "NASM Certified" },
      {
        "@type": "EducationalOccupationalCredential",
        name: "Functional Nutrition & Lifestyle Practitioner (FNLP), Functional Nutrition Alliance",
      },
    ],
  },
];
---

<BaseLayout
  title="Personal Training, Water Training & Nutrition Coaching"
  description={DEFAULT_DESCRIPTION}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <main id="main">
    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="wrap hero-inner">
        <div class="hero-copy">
          <span class="eyebrow-script">Join the Fit Life</span>
          <h1>
            Move Better.<br />
            <span class="alt">Feel Stronger.</span><br />
            Live Healthier.
          </h1>
          <p class="hero-sub">
            Personalized wellness &amp; fitness programs with
            <strong>Kristy Bussard, FNLP</strong> — Certified Health &amp; Wellness
            Practitioner. Whether you're recovering from an injury or simply want a safe,
            supportive way to stay active, every program is designed around
            <strong>your</strong> goals and abilities.
          </p>
          <div class="hero-actions">
            <a href="#contact" class="button button-primary">
              Schedule a Consultation
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href={`tel:${PHONE_TEL}`} class="button button-ghost">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Call {PHONE_DISPLAY}
            </a>
          </div>
          <ul class="hero-badges" aria-label="Credentials">
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              NASM Certified
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
              FNLP &middot; Functional Nutrition Alliance
            </li>
            <li>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
              Safety-First Coaching
            </li>
          </ul>
        </div>

        <div class="hero-rail" aria-label="Services overview">
          <a href="#services" class="hero-card hero-card-featured">
            <span class="icon-chip chip-aqua">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3c4 4.9 6.5 8.4 6.5 11.5a6.5 6.5 0 1 1-13 0C5.5 11.4 8 7.9 12 3Z"/></svg>
            </span>
            <span class="hero-card-copy">
              <strong>Water Training</strong>
              <span>Low-impact, joint-friendly, full-body</span>
            </span>
            <span class="badge-specialty">My Specialty!</span>
          </a>
          <a href="#services" class="hero-card">
            <span class="icon-chip chip-green">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            </span>
            <span class="hero-card-copy">
              <strong>Nutrition Coaching</strong>
              <span>Practical plans that fit your lifestyle</span>
            </span>
            <svg class="hero-card-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#services" class="hero-card">
            <span class="icon-chip chip-navy">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.4 14.4 9.6 9.6"/><path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767 1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l-1.768 1.767a2 2 0 1 1 2.828 2.829z"/><path d="m21.5 21.5-1.4-1.4"/><path d="M3.9 3.9 2.5 2.5"/><path d="M6.404 12.768a2 2 0 1 1-2.829-2.829l1.768-1.767a2 2 0 1 1-2.828-2.829l2.828-2.828a2 2 0 1 1 2.829 2.828l1.767-1.768a2 2 0 1 1 2.829 2.829z"/></svg>
            </span>
            <span class="hero-card-copy">
              <strong>1-on-1 Personal Training</strong>
              <span>Strength, balance &amp; mobility</span>
            </span>
            <svg class="hero-card-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
      <div class="wave" aria-hidden="true">
        <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
          <path
            fill="rgba(245, 249, 251, 0.35)"
            d="M0,52 C240,104 480,108 720,72 C960,38 1200,42 1440,84 L1440,120 L0,120 Z"
          ></path>
          <path
            fill="#f5f9fb"
            d="M0,72 C240,116 480,116 720,86 C960,58 1200,58 1440,94 L1440,120 L0,120 Z"
          ></path>
        </svg>
      </div>
    </section>

    <!-- ============ COMMITMENT / VALUES ============ -->
    <section id="about" class="section">
      <div class="wrap commitment-grid">
        <div class="commitment-copy">
          <span class="eyebrow-script">Your Goals. My Commitment.</span>
          <h2>A Safe, Personal Path to Feeling Your Best</h2>
          <p class="lead">
            Whether you're recovering from an injury, looking to improve your health, or
            simply want a safe and effective way to stay active, I provide personalized
            programs designed around your individual goals and abilities.
          </p>
          <p class="lead">
            No intimidating gyms. No one-size-fits-all plans. Just steady, encouraging
            coaching that meets you exactly where you are today.
          </p>
        </div>
        <div class="values">
          <article class="value-card">
            <span class="icon-chip chip-aqua">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
            </span>
            <div>
              <h3>Safety</h3>
              <p>Your safety is my top priority — every movement is chosen for your body and abilities.</p>
            </div>
          </article>
          <article class="value-card">
            <span class="icon-chip chip-green">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
            </span>
            <div>
              <h3>Support</h3>
              <p>Encouragement every step of the way, at a pace that feels right for you.</p>
            </div>
          </article>
          <article class="value-card">
            <span class="icon-chip chip-navy">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
            </span>
            <div>
              <h3>Results</h3>
              <p>Real progress you can feel — more strength, better balance, more confidence. Real you.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ SERVICES ============ -->
    <section id="services" class="section section-tint">
      <div class="wrap">
        <div class="section-head center">
          <span class="eyebrow-script">Services Offered</span>
          <h2>Three Ways to Build a Stronger, Healthier You</h2>
          <p>
            Every program is individualized — we'll find the combination that fits your
            body, your schedule, and your goals.
          </p>
        </div>

        <div class="services-grid">
          <article class="service-card service-featured">
            <span class="service-flag">My Specialty</span>
            <span class="icon-chip chip-aqua">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3c4 4.9 6.5 8.4 6.5 11.5a6.5 6.5 0 1 1-13 0C5.5 11.4 8 7.9 12 3Z"/></svg>
            </span>
            <h3>Water Training</h3>
            <p class="service-specialty">Gentle on joints, big on results</p>
            <ul>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Perfect for individuals who don't feel comfortable in a traditional gym
              </li>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Low-impact exercise that's gentle on joints
              </li>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Full-body workouts that strengthen every major muscle group
              </li>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Great for beginners, seniors, injury recovery, arthritis, balance
                improvement, and overall fitness
              </li>
            </ul>
          </article>

          <article class="service-card">
            <span class="icon-chip chip-green">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
            </span>
            <h3>Nutrition Coaching</h3>
            <p class="service-specialty">Fuel that works for real life</p>
            <ul>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Practical nutrition guidance for healthier living
              </li>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Personalized plans that fit your lifestyle
              </li>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Support for weight management, energy, and long-term wellness
              </li>
            </ul>
          </article>

          <article class="service-card">
            <span class="icon-chip chip-navy">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.4 14.4 9.6 9.6"/><path d="M18.657 21.485a2 2 0 1 1-2.829-2.828l-1.767 1.768a2 2 0 1 1-2.829-2.829l6.364-6.364a2 2 0 1 1 2.829 2.829l-1.768 1.767a2 2 0 1 1 2.828 2.829z"/><path d="m21.5 21.5-1.4-1.4"/><path d="M3.9 3.9 2.5 2.5"/><path d="M6.404 12.768a2 2 0 1 1-2.829-2.829l1.768-1.767a2 2 0 1 1-2.828-2.829l2.828-2.828a2 2 0 1 1 2.829 2.828l1.767-1.768a2 2 0 1 1 2.829 2.829z"/></svg>
            </span>
            <h3>One-on-One Personal Training</h3>
            <p class="service-specialty">Your program, your pace</p>
            <ul>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Individualized fitness programs
              </li>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Strength, flexibility, balance, and mobility training
              </li>
              <li>
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                Sessions tailored to your fitness level and personal goals
              </li>
            </ul>
          </article>
        </div>

        <div class="services-tagline">
          <span class="script">Personalized. Effective. Sustainable.</span>
          <strong>You Are Worth It.</strong>
        </div>
      </div>
    </section>

    <!-- ============ WHO CAN BENEFIT ============ -->
    <section id="who" class="section">
      <div class="wrap">
        <div class="benefit">
          <div class="benefit-copy">
            <span class="eyebrow-script">Is this for me?</span>
            <h2>Who Can Benefit</h2>
            <p>
              If any of these sound like you, you're exactly who these programs were
              built for — and there's no fitness level required to start.
            </p>
            <a href="#contact" class="button button-primary">Let's Talk About Your Goals</a>
          </div>
          <ul class="benefit-list">
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
              Individuals recovering from injury or surgery
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
              Clients referred by physical therapists
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
              Older adults
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
              Beginners to exercise
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
              Anyone seeking a healthier lifestyle
            </li>
            <li>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21.801 10A10 10 0 1 1 17 3.335"/><path d="m9 11 3 3L22 4"/></svg>
              Anyone looking for a safe, supportive fitness experience
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============ PRICING ============ -->
    <section id="pricing" class="section" style="padding-top: 0;">
      <div class="wrap">
        <div class="pricing-card">
          <span class="eyebrow-script">Personalized Pricing</span>
          <h2>Every Person Is Unique — So Is Every Program</h2>
          <p>
            <strong>Fees are discussed individually</strong> based on your specific needs,
            goals, and circumstances. Your first step is a friendly, no-pressure
            consultation where we talk through what you're hoping to achieve.
          </p>
          <a href="#contact" class="button button-navy">Schedule Your Consultation</a>
        </div>
      </div>
    </section>

    <!-- ============ BLOG STRIP ============ -->
    <section class="section section-tint">
      <div class="wrap">
        <div class="section-head center">
          <span class="eyebrow-script">From the Blog</span>
          <h2>Tips &amp; Encouragement Between Sessions</h2>
          <p>
            Practical advice on moving well, eating well, and staying active — written by
            Kristy.
          </p>
        </div>
        {latestPosts.length ? (
          <div class="blog-grid">
            {latestPosts.map((post) => (
              <article class="blog-card" aria-labelledby={`home-post-${post.slug}`}>
                {post.coverImage ? (
                  <a href={`/blog/${post.slug}`} class="blog-card-image">
                    <img src={post.coverImage} alt={post.title} loading="lazy" decoding="async" />
                  </a>
                ) : null}
                <div class="blog-card-copy">
                  <p class="blog-card-meta">
                    <span>
                      {new Date(post.publishDate).toLocaleDateString("en-US", {
                        month: "long",
                        day: "numeric",
                        year: "numeric",
                      })}
                    </span>
                    {post.tags?.length ? <span>{post.tags[0]}</span> : null}
                  </p>
                  <h3 id={`home-post-${post.slug}`}>
                    <a href={`/blog/${post.slug}`}>{post.title}</a>
                  </h3>
                  <p>{post.excerpt}</p>
                </div>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <p>The blog is ready to go — Kristy's first articles are coming soon!</p>
          </div>
        )}
        <div class="strip-footer">
          <a href="/blog" class="button button-outline">Visit the Blog</a>
        </div>
      </div>
    </section>

    <!-- ============ CONTACT ============ -->
    <section id="contact" class="contact-section">
      <div class="wrap contact-grid">
        <div class="contact-intro">
          <span class="eyebrow-script">Let's Get Started!</span>
          <h2>Schedule a Consultation</h2>
          <p>
            Discover a wellness program that's designed just for you. Reach out directly,
            or send a note with the form and Kristy will follow up personally.
          </p>
          <ul class="contact-methods">
            <li>
              <a href={`tel:${PHONE_TEL}`}>
                <span class="icon-chip chip-aqua">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </span>
                <span>
                  {PHONE_DISPLAY}
                  <small>Call or text</small>
                </span>
              </a>
            </li>
            <li>
              <a href={`mailto:${EMAIL}`}>
                <span class="icon-chip chip-green">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </span>
                <span>
                  {EMAIL}
                  <small>Email anytime</small>
                </span>
              </a>
            </li>
          </ul>
          <p style="margin-top: 2rem; font-family: var(--font-script); font-size: 1.35rem; color: var(--aqua-300);">
            {MISSION}
          </p>
        </div>

        <form
          id="contact-form"
          class="contact-form"
          action="https://formspree.io/f/meelknyk"
          method="POST"
          novalidate
        >
          <div class="field-grid">
            <label>
              Full Name
              <input
                type="text"
                name="name"
                autocomplete="name"
                minlength="2"
                maxlength="80"
                required
              />
            </label>
            <label>
              Email
              <input type="email" name="email" autocomplete="email" maxlength="120" required />
            </label>
            <label>
              Phone
              <input type="tel" name="phone" autocomplete="tel" inputmode="tel" maxlength="24" />
            </label>
            <label>
              Preferred Contact
              <select name="preferredContact" required>
                <option value="">Select one</option>
                <option>Email</option>
                <option>Phone</option>
                <option>Either</option>
              </select>
            </label>
          </div>

          <label>
            I'm interested in&hellip;
            <select name="interest" required>
              <option value="">Select a service</option>
              <option>Water Training</option>
              <option>Nutrition Coaching</option>
              <option>One-on-One Personal Training</option>
              <option>A combination / not sure yet</option>
            </select>
          </label>

          <label>
            What are your goals?
            <textarea
              name="goals"
              rows="4"
              minlength="24"
              maxlength="1200"
              placeholder="For example: recovering from knee surgery, building balance and strength, feeling more energetic..."
              required></textarea>
          </label>

          <input
            type="text"
            name="company"
            class="hp-field"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
          <input type="hidden" name="landingSource" value="" />
          <input type="hidden" name="landingMedium" value="" />
          <input type="hidden" name="landingCampaign" value="" />
          <input type="hidden" name="landingReferrer" value="" />
          <input type="hidden" name="aiAssisted" value="false" />

          <label class="consent">
            <input type="checkbox" name="consent" required />
            <span>I agree to be contacted about Kristy Fitness programs and services.</span>
          </label>

          <button type="submit" class="button button-primary">Send My Message</button>
          <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>
