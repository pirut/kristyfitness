---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllPosts } from "../lib/blog";
import {
  DEFAULT_DESCRIPTION,
  EMAIL,
  MISSION,
  PHONE_DISPLAY,
  PHONE_TEL,
  SITE_NAME,
  SITE_URL,
} from "../lib/site";

export const prerender = true;

const latestPosts = (await getAllPosts()).slice(0, 3);

const jsonLd = [
  {
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    url: `${SITE_URL}/`,
    name: SITE_NAME,
    description: DEFAULT_DESCRIPTION,
    inLanguage: "en-US",
  },
  {
    "@type": "HealthAndBeautyBusiness",
    "@id": `${SITE_URL}/#business`,
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    slogan: "Join the Fit Life",
    description: DEFAULT_DESCRIPTION,
    telephone: PHONE_DISPLAY,
    email: EMAIL,
    founder: { "@id": `${SITE_URL}/#kristy` },
    makesOffer: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Water Training",
          description:
            "Low-impact, full-body water workouts that are gentle on joints — great for beginners, seniors, injury recovery, arthritis, and balance improvement.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Nutrition Coaching",
          description:
            "Practical nutrition guidance and personalized plans for weight management, energy, and long-term wellness.",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "One-on-One Personal Training",
          description:
            "Individualized fitness programs for strength, flexibility, balance, and mobility, tailored to your fitness level and goals.",
        },
      },
    ],
  },
  {
    "@type": "Person",
    "@id": `${SITE_URL}/#kristy`,
    name: "Kristy Bussard",
    honorificSuffix: "FNLP",
    jobTitle: "Certified Health & Wellness Practitioner",
    telephone: PHONE_DISPLAY,
    email: EMAIL,
    url: `${SITE_URL}/`,
    hasCredential: [
      { "@type": "EducationalOccupationalCredential", name: "NASM Certified" },
      {
        "@type": "EducationalOccupationalCredential",
        name: "Functional Nutrition & Lifestyle Practitioner (FNLP), Functional Nutrition Alliance",
      },
    ],
  },
];
---

<BaseLayout
  title="Personal Training, Water Training & Nutrition Coaching"
  description={DEFAULT_DESCRIPTION}
  canonicalPath="/"
  jsonLd={jsonLd}
>
  <main id="main">
    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="wrap hero-inner">
        <div class="hero-copy" data-reveal>
          <p class="hero-kicker">Join the Fit Life</p>
          <h1>
            Move Better.<br />
            <span>Feel Stronger.</span><br />
            Live Healthier.
          </h1>
          <p class="hero-sub">
            Personalized wellness &amp; fitness programs with
            <strong>Kristy Bussard, FNLP</strong> — Certified Health &amp; Wellness
            Practitioner. Whether you're recovering from an injury or simply want a safe,
            supportive way to stay active, every program is designed around
            <strong>your</strong> goals and abilities.
          </p>
          <div class="hero-actions">
            <a href="#contact" class="button button-primary">
              Schedule a Consultation
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <a href={`tel:${PHONE_TEL}`} class="hero-phone">Call {PHONE_DISPLAY}</a>
          </div>
          <ul class="hero-proof" aria-label="Credentials">
            <li>NASM Certified</li>
            <li>FNLP &middot; Functional Nutrition Alliance</li>
            <li>Safety-First Coaching</li>
          </ul>
        </div>

        <figure class="hero-pool" data-reveal>
          <svg class="pool-art" viewBox="0 0 580 690" role="img" aria-label="An abstract view of calm swimming-pool lanes">
            <defs>
              <pattern id="pool-grid" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M40 0H0V40" fill="none" stroke="currentColor" stroke-opacity=".14" />
              </pattern>
              <linearGradient id="pool-wash" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#a7e6e8" />
                <stop offset="1" stop-color="#56b8c4" />
              </linearGradient>
            </defs>
            <rect width="580" height="690" rx="12" fill="url(#pool-wash)" />
            <rect width="580" height="690" rx="12" fill="url(#pool-grid)" />
            <path d="M-20 148C109 98 212 213 352 154C461 108 509 124 620 186" fill="none" stroke="#f8fbf7" stroke-width="18" stroke-linecap="round" />
            <path d="M-10 305C124 257 234 374 370 312C474 265 529 291 620 345" fill="none" stroke="#0b3850" stroke-opacity=".7" stroke-width="10" stroke-linecap="round" />
            <path d="M-20 481C113 429 232 550 370 487C478 439 535 466 620 522" fill="none" stroke="#f8fbf7" stroke-width="18" stroke-linecap="round" />
            <circle cx="98" cy="148" r="13" fill="#f0b75f" />
            <circle cx="178" cy="148" r="13" fill="#f0b75f" />
            <circle cx="258" cy="165" r="13" fill="#f0b75f" />
            <circle cx="415" cy="147" r="13" fill="#f0b75f" />
            <circle cx="489" cy="143" r="13" fill="#f0b75f" />
            <circle cx="82" cy="482" r="13" fill="#e56f5d" />
            <circle cx="163" cy="489" r="13" fill="#e56f5d" />
            <circle cx="245" cy="500" r="13" fill="#e56f5d" />
            <circle cx="403" cy="478" r="13" fill="#e56f5d" />
            <circle cx="482" cy="477" r="13" fill="#e56f5d" />
          </svg>
          <div class="pool-caption">
            <span>My Specialty!</span>
            <strong>Water Training</strong>
            <p>Low-impact, joint-friendly, full-body</p>
          </div>
          <figcaption>Join the Fit Life</figcaption>
          <div class="hero-mini-services" aria-label="Additional services">
            <p><strong>Nutrition Coaching</strong><span>Practical plans that fit your lifestyle</span></p>
            <p><strong>1-on-1 Personal Training</strong><span>Strength, balance &amp; mobility</span></p>
          </div>
        </figure>
      </div>
    </section>

    <!-- ============ APPROACH ============ -->
    <section id="about" class="section approach-section">
      <div class="wrap approach-grid">
        <div class="approach-copy" data-reveal>
          <p class="section-kicker">Your Goals. My Commitment.</p>
          <h2>A Safe, Personal Path to Feeling Your Best</h2>
          <p>
            Whether you're recovering from an injury, looking to improve your health, or
            simply want a safe and effective way to stay active, I provide personalized
            programs designed around your individual goals and abilities.
          </p>
          <p>
            No intimidating gyms. No one-size-fits-all plans. Just steady, encouraging
            coaching that meets you exactly where you are today.
          </p>
        </div>
        <ol class="approach-list" data-reveal>
          <li>
            <span>01</span>
            <div><h3>Safety</h3><p>Your safety is my top priority — every movement is chosen for your body and abilities.</p></div>
          </li>
          <li>
            <span>02</span>
            <div><h3>Support</h3><p>Encouragement every step of the way, at a pace that feels right for you.</p></div>
          </li>
          <li>
            <span>03</span>
            <div><h3>Results</h3><p>Real progress you can feel — more strength, better balance, more confidence. Real you.</p></div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ============ SERVICES ============ -->
    <section id="services" class="section services-editorial">
      <div class="wrap">
        <div class="services-heading" data-reveal>
          <p class="section-kicker">Services Offered</p>
          <h2>Three Ways to Build a Stronger, Healthier You</h2>
          <p>Every program is individualized — we'll find the combination that fits your body, your schedule, and your goals.</p>
        </div>

        <article class="water-service" data-reveal>
          <div class="service-number">01</div>
          <div class="water-service-copy">
            <p class="service-label">My Specialty</p>
            <h3>Water Training</h3>
            <p class="service-lead">Gentle on joints, big on results</p>
            <ul>
              <li>Perfect for individuals who don't feel comfortable in a traditional gym</li>
              <li>Low-impact exercise that's gentle on joints</li>
              <li>Full-body workouts that strengthen every major muscle group</li>
              <li>Great for beginners, seniors, injury recovery, arthritis, balance improvement, and overall fitness</li>
            </ul>
          </div>
          <div class="water-rings" aria-hidden="true"><i></i><i></i><i></i></div>
        </article>

        <div class="service-lines">
          <article class="service-line" data-reveal>
            <span class="service-number">02</span>
            <div>
              <h3>Nutrition Coaching</h3>
              <p class="service-specialty">Fuel that works for real life</p>
              <ul>
                <li>Practical nutrition guidance for healthier living</li>
                <li>Personalized plans that fit your lifestyle</li>
                <li>Support for weight management, energy, and long-term wellness</li>
              </ul>
            </div>
          </article>
          <article class="service-line" data-reveal>
            <span class="service-number">03</span>
            <div>
              <h3>One-on-One Personal Training</h3>
              <p class="service-specialty">Your program, your pace</p>
              <ul>
                <li>Individualized fitness programs</li>
                <li>Strength, flexibility, balance, and mobility training</li>
                <li>Sessions tailored to your fitness level and personal goals</li>
              </ul>
            </div>
          </article>
        </div>
        <div class="services-tagline">
          <span class="script">Personalized. Effective. Sustainable.</span>
          <strong>You Are Worth It.</strong>
        </div>
      </div>
    </section>

    <!-- ============ WHO CAN BENEFIT + PRICING ============ -->
    <section id="who" class="section fit-section">
      <div class="wrap fit-grid">
        <div data-reveal>
          <p class="section-kicker">Is this for me?</p>
          <h2>Who Can Benefit</h2>
          <p class="fit-intro">If any of these sound like you, you're exactly who these programs were built for — and there's no fitness level required to start.</p>
          <ul class="fit-list">
            <li>Individuals recovering from injury or surgery</li>
            <li>Clients referred by physical therapists</li>
            <li>Older adults</li>
            <li>Beginners to exercise</li>
            <li>Anyone seeking a healthier lifestyle</li>
            <li>Anyone looking for a safe, supportive fitness experience</li>
          </ul>
          <a href="#contact" class="button button-primary fit-button">Let's Talk About Your Goals</a>
        </div>
        <aside id="pricing" class="start-note" data-reveal>
          <p class="start-note-script">Personalized Pricing</p>
          <h3>Every Person Is Unique — So Is Every Program</h3>
          <p>
            <strong>Fees are discussed individually</strong> based on your specific needs,
            goals, and circumstances. Your first step is a friendly, no-pressure
            consultation where we talk through what you're hoping to achieve.
          </p>
          <a href="#contact" class="button button-primary">Schedule a Consultation</a>
        </aside>
      </div>
    </section>

    <!-- ============ BLOG STRIP ============ -->
    <section class="section journal-section">
      <div class="wrap journal-layout">
        <div class="journal-heading" data-reveal>
          <p class="section-kicker">From the Blog</p>
          <h2>Tips &amp; Encouragement Between Sessions</h2>
          <p>Practical advice on moving well, eating well, and staying active — written by Kristy.</p>
          <a href="/blog" class="text-link">Visit the Blog <span aria-hidden="true">→</span></a>
        </div>
        {latestPosts.length ? (
          <div class="journal-entries" data-reveal>
            {latestPosts.map((post) => (
              <article class="journal-entry" aria-labelledby={`home-post-${post.slug}`}>
                {post.coverImage ? (
                  <a href={`/blog/${post.slug}`} class="journal-entry-image">
                    <img src={post.coverImage} alt={post.title} loading="lazy" decoding="async" />
                  </a>
                ) : null}
                <div class="journal-entry-copy">
                  <time datetime={post.publishDate}>
                    {new Date(post.publishDate).toLocaleDateString("en-US", {
                      month: "long",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </time>
                  {post.tags?.length ? <span class="journal-entry-tag">{post.tags[0]}</span> : null}
                  <h3 id={`home-post-${post.slug}`}>
                    <a href={`/blog/${post.slug}`}>{post.title}</a>
                  </h3>
                  <p>{post.excerpt}</p>
                </div>
                <a href={`/blog/${post.slug}`} class="journal-entry-arrow" aria-label={`Read ${post.title}`}>→</a>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <p>The blog is ready to go — Kristy's first articles are coming soon!</p>
          </div>
        )}
      </div>
    </section>

    <!-- ============ CONTACT ============ -->
    <section id="contact" class="contact-section">
      <div class="wrap contact-grid">
        <div class="contact-intro" data-reveal>
          <p class="section-kicker">Let's Get Started!</p>
          <h2>Schedule a Consultation</h2>
          <p>
            Discover a wellness program that's designed just for you. Reach out directly,
            or send a note with the form and Kristy will follow up personally.
          </p>
          <ul class="contact-methods">
            <li>
              <a href={`tel:${PHONE_TEL}`}>
                <span class="icon-chip chip-aqua">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </span>
                <span>
                  {PHONE_DISPLAY}
                  <small>Call or text</small>
                </span>
              </a>
            </li>
            <li>
              <a href={`mailto:${EMAIL}`}>
                <span class="icon-chip chip-green">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                </span>
                <span>
                  {EMAIL}
                  <small>Email anytime</small>
                </span>
              </a>
            </li>
          </ul>
          <p class="contact-mission">
            {MISSION}
          </p>
        </div>

        <form
          id="contact-form"
          class="contact-form"
          data-reveal
          action="https://formspree.io/f/meelknyk"
          method="POST"
          novalidate
        >
          <div class="field-grid">
            <label>
              Full Name
              <input
                type="text"
                name="name"
                autocomplete="name"
                minlength="2"
                maxlength="80"
                required
              />
            </label>
            <label>
              Email
              <input type="email" name="email" autocomplete="email" maxlength="120" required />
            </label>
            <label>
              Phone
              <input type="tel" name="phone" autocomplete="tel" inputmode="tel" maxlength="24" />
            </label>
            <label>
              Preferred Contact
              <select name="preferredContact" required>
                <option value="">Select one</option>
                <option>Email</option>
                <option>Phone</option>
                <option>Either</option>
              </select>
            </label>
          </div>

          <label>
            I'm interested in&hellip;
            <select name="interest" required>
              <option value="">Select a service</option>
              <option>Water Training</option>
              <option>Nutrition Coaching</option>
              <option>One-on-One Personal Training</option>
              <option>A combination / not sure yet</option>
            </select>
          </label>

          <label>
            What are your goals?
            <textarea
              name="goals"
              rows="4"
              minlength="24"
              maxlength="1200"
              placeholder="For example: recovering from knee surgery, building balance and strength, feeling more energetic..."
              required></textarea>
          </label>

          <input
            type="text"
            name="company"
            class="hp-field"
            tabindex="-1"
            autocomplete="off"
            aria-hidden="true"
          />
          <input type="hidden" name="landingSource" value="" />
          <input type="hidden" name="landingMedium" value="" />
          <input type="hidden" name="landingCampaign" value="" />
          <input type="hidden" name="landingReferrer" value="" />
          <input type="hidden" name="aiAssisted" value="false" />

          <label class="consent">
            <input type="checkbox" name="consent" required />
            <span>I agree to be contacted about Kristy Fitness programs and services.</span>
          </label>

          <button type="submit" class="button button-primary">Send My Message</button>
          <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>
</BaseLayout>
